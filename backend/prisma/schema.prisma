generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  AGENT
}

enum TicketStatus {
  OPEN
  RESOLVED
  CLOSED
}

enum TicketCategory {
  GENERAL_QUESTION
  TECHNICAL_QUESTION
  REFUND_REQUEST
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      UserRole @default(AGENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
  tickets  Ticket[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
}

model Ticket {
  id        String         @id @default(cuid())
  email     String
  subject   String
  body      String
  status    TicketStatus   @default(OPEN)
  category  TicketCategory
  summary   String?
  agentId   String?
  agent     User?          @relation(fields: [agentId], references: [id])
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  replies Reply[]

  @@index([agentId])
  @@index([status])
}

model Reply {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  content   String
  isAI      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ticketId])
}
